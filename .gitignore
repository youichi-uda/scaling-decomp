__pycache__/
*.pyc
*.pyo
.venv/
.ipynb_checkpoints/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Large or transient ad-hoc outputs that aren't reproducible-from-source:
*.tmp
*.bak
